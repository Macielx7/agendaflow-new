generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum UserRole {
  ADMIN
  STAFF
}

enum SuperAdminRole {
  SUPER_ADMIN
  DEVELOPER
  SUPPORT
}

enum TenantStatus {
  ACTIVE
  PENDING
  SUSPENDED
  CANCELLED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PENDING
  SUSPENDED
  CANCELLED
  EXPIRED
}

enum BillingStatus {
  PAID
  PENDING
  FAILED
  REFUNDED
}

enum WhatsappConnectionStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
  EXPIRED
}

enum WhatsappMessageType {
  CONFIRMATION
  REMINDER
  CANCELLATION
  RESCHEDULE
  COMPLETION
  MANUAL
}

enum WhatsappMessageStatus {
  PENDING
  SENT
  FAILED
}

enum WhatsappTemplateType {
  CONFIRMATION
  REMINDER
  CANCELLATION
  RESCHEDULE
  COMPLETION
}

model SuperAdmin {
  id        String         @id @default(cuid())
  email     String         @unique
  password  String
  name      String
  role      SuperAdminRole @default(SUPER_ADMIN)
  active    Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  logs      SystemLog[]

  @@map("super_admins")
}

model Plan {
  id                String         @id @default(cuid())
  slug              String         @unique
  name              String
  description       String?
  priceMonthly      Decimal        @default(0) @db.Decimal(10, 2)
  priceYearly       Decimal        @default(0) @db.Decimal(10, 2)
  maxUsers          Int            @default(1)
  maxAppointments   Int            @default(100)
  features          String         @default("[]")
  active            Boolean        @default(true)
  sortOrder         Int            @default(0)
  subscriptions     Subscription[]
  tenants           Tenant[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@map("plans")
}

model Tenant {
  id              String              @id @default(cuid())
  slug            String              @unique
  companyName     String
  ownerName       String
  email           String
  phone           String?
  status          TenantStatus        @default(PENDING)
  planId          String?
  plan            Plan?               @relation(fields: [planId], references: [id])
  subscription    Subscription?
  lastAccessAt    DateTime?
  users           User[]
  clients         Client[]
  services        Service[]
  schedules       Schedule[]
  holidays        Holiday[]
  appointments    Appointment[]
  settings        Setting[]
  billingHistory  BillingHistory[]
  featurePermissions FeaturePermission[]
  logs            SystemLog[]
  whatsappInstance WhatsappInstance?
  whatsappSettings WhatsappSettings?
  whatsappTemplates WhatsappTemplate[]
  whatsappMessages WhatsappMessage[]
  whatsappLogs     WhatsappLog[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([status])
  @@index([email])
  @@map("tenants")
}

model Subscription {
  id           String             @id @default(cuid())
  tenantId     String             @unique
  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId       String
  plan         Plan               @relation(fields: [planId], references: [id])
  status       SubscriptionStatus @default(TRIAL)
  trialEndsAt  DateTime?
  startsAt     DateTime           @default(now())
  endsAt       DateTime?
  renewedAt    DateTime?
  cancelledAt  DateTime?
  billingCycle String             @default("monthly")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([status])
  @@map("subscriptions")
}

model BillingHistory {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  amount      Decimal       @db.Decimal(10, 2)
  description String?
  status      BillingStatus @default(PENDING)
  paidAt      DateTime?
  dueAt       DateTime?
  createdAt   DateTime      @default(now())

  @@index([tenantId])
  @@map("billing_history")
}

model FeaturePermission {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  module    String
  enabled   Boolean  @default(true)
  limit     Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, module])
  @@map("feature_permissions")
}

model SystemLog {
  id           String      @id @default(cuid())
  tenantId     String?
  tenant       Tenant?     @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  superAdminId String?
  superAdmin   SuperAdmin? @relation(fields: [superAdminId], references: [id], onDelete: SetNull)
  action       String
  details      String?
  ip           String?
  createdAt    DateTime    @default(now())

  @@index([tenantId])
  @@index([createdAt])
  @@map("system_logs")
}

model User {
  id               String    @id @default(cuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email            String
  password         String
  name             String
  role             UserRole  @default(ADMIN)
  avatar           String?
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model Client {
  id           String        @id @default(cuid())
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  phone        String
  email        String?
  notes        String?
  appointments Appointment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([tenantId])
  @@index([phone])
  @@index([name])
  @@map("clients")
}

model Service {
  id           String        @id @default(cuid())
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  slug         String
  name         String
  description  String?
  duration     Int           @default(60)
  price        Decimal       @default(0) @db.Decimal(10, 2)
  active       Boolean       @default(true)
  sortOrder    Int           @default(0)
  appointments Appointment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("services")
}

model Schedule {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dayOfWeek    Int
  startTime    String
  endTime      String
  slotDuration Int      @default(60)
  breakStart   String?
  breakEnd     String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, dayOfWeek])
  @@map("schedules")
}

model Holiday {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  name      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, date])
  @@map("holidays")
}

model Appointment {
  id        String            @id @default(cuid())
  tenantId  String
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client            @relation(fields: [clientId], references: [id])
  serviceId String
  service   Service           @relation(fields: [serviceId], references: [id])
  date      DateTime          @db.Date
  time      String
  notes     String?
  status    AppointmentStatus @default(PENDING)
  price     Decimal?          @db.Decimal(10, 2)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([tenantId, date, time])
  @@index([tenantId])
  @@index([status])
  @@index([date])
  @@index([clientId])
  @@map("appointments")
}

model Setting {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  key       String
  value     String
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, key])
  @@map("settings")
}

model WhatsappInstance {
  id              String                   @id @default(cuid())
  tenantId        String                   @unique
  tenant          Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  instanceName    String                   @unique
  status          WhatsappConnectionStatus @default(DISCONNECTED)
  phoneNumber     String?
  profileName     String?
  qrCode          String?                  @db.Text
  qrExpiresAt     DateTime?
  connectedAt     DateTime?
  disconnectedAt  DateTime?
  lastEventAt     DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  @@index([status])
  @@map("whatsapp_instances")
}

model WhatsappSettings {
  id                    String   @id @default(cuid())
  tenantId              String   @unique
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  confirmationsEnabled  Boolean  @default(true)
  remindersEnabled      Boolean  @default(true)
  cancellationsEnabled  Boolean  @default(true)
  reschedulesEnabled    Boolean  @default(true)
  completionsEnabled    Boolean  @default(true)
  reminderHoursBefore   Int      @default(24)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("whatsapp_settings")
}

model WhatsappTemplate {
  id        String               @id @default(cuid())
  tenantId  String
  tenant    Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type      WhatsappTemplateType
  content   String               @db.Text
  active    Boolean              @default(true)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@unique([tenantId, type])
  @@map("whatsapp_templates")
}

model WhatsappMessage {
  id            String                @id @default(cuid())
  tenantId      String
  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointmentId String?
  clientPhone   String
  clientName    String?
  type          WhatsappMessageType
  content       String                @db.Text
  status        WhatsappMessageStatus @default(PENDING)
  errorMessage  String?
  externalId    String?
  sentAt        DateTime?
  createdAt     DateTime              @default(now())

  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@map("whatsapp_messages")
}

model WhatsappLog {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  event     String
  payload   String?  @db.Text
  level     String   @default("info")
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([createdAt])
  @@map("whatsapp_logs")
}
